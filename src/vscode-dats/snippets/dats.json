{
  "DATS Test File": {
    "prefix": "dats",
    "body": [
      "tests:",
      "  - name: ${1:test name}",
      "    exit: ${2:0}",
      "    cmd: ${3:echo hello}",
      "    outputs:",
      "      stdout:",
      "        - \"${4:expected output}\""
    ],
    "description": "Create a new DATS test file"
  },
  "Test Case": {
    "prefix": "test",
    "body": [
      "- name: ${1:test name}",
      "  exit: ${2:0}",
      "  cmd: ${3:command}",
      "  outputs:",
      "    stdout:",
      "      - \"${4:expected}\""
    ],
    "description": "Add a new test case"
  },
  "Test with Input File": {
    "prefix": "test-input",
    "body": [
      "- name: ${1:test name}",
      "  exit: ${2:0}",
      "  inputs:",
      "    ${3:input.txt}: |",
      "      ${4:file content}",
      "  cmd: ${5:cat} {inputs.${3:input.txt}}",
      "  outputs:",
      "    stdout:",
      "      - \"${6:expected}\""
    ],
    "description": "Add a test case with input file"
  },
  "Test with Stdin": {
    "prefix": "test-stdin",
    "body": [
      "- name: ${1:test name}",
      "  exit: ${2:0}",
      "  stdin: \"${3:input data}\"",
      "  cmd: ${4:cat}",
      "  outputs:",
      "    stdout:",
      "      - \"${5:expected}\""
    ],
    "description": "Add a test case with stdin input"
  },
  "Test with Output File": {
    "prefix": "test-output",
    "body": [
      "- name: ${1:test name}",
      "  exit: ${2:0}",
      "  inputs:",
      "    ${3:input.txt}: |",
      "      ${4:content}",
      "  cmd: ${5:cp} {inputs.${3:input.txt}} {outputs.${6:output.txt}}",
      "  outputs:",
      "    ${6:output.txt}:",
      "      exists: true",
      "      contains:",
      "        - \"${7:expected}\""
    ],
    "description": "Add a test case with output file validation"
  },
  "Inputs Block": {
    "prefix": "inputs",
    "body": [
      "inputs:",
      "  ${1:filename}: |",
      "    ${2:content}"
    ],
    "description": "Add an inputs block"
  },
  "Outputs Block": {
    "prefix": "outputs",
    "body": [
      "outputs:",
      "  stdout:",
      "    - \"${1:pattern}\""
    ],
    "description": "Add an outputs block"
  },
  "Line Check": {
    "prefix": "line",
    "body": [
      "${1:0}: \"${2:^pattern$}\""
    ],
    "description": "Add a line-specific assertion"
  },
  "Negative Assertion": {
    "prefix": "refute",
    "body": [
      "\"!${1:stdout}\":",
      "  - \"${2:unwanted pattern}\""
    ],
    "description": "Add a negative assertion"
  }
}
